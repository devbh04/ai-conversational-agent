# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Infrastructure (Required) ────────────────────────────────────────────────

# LiveKit Cloud — https://cloud.livekit.io/ → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Supabase — https://app.supabase.com/ → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Backend FastAPI server URL (used by agents to reach the backend)
BACKEND_API_URL=http://localhost:8001

# ── AI Providers (Required — at least OpenAI + Sarvam) ───────────────────────

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional AI providers (enable in agent config.json)
ANTHROPIC_API_KEY=                       # For Claude Haiku 3.5
GROQ_API_KEY=                            # For Groq Llama models
DEEPGRAM_API_KEY=                        # For Deepgram STT Nova-2
ELEVENLABS_API_KEY=                      # For ElevenLabs TTS

# ── Real Estate Agent — Cal.com (Optional) ───────────────────────────────────
# Only needed if you want the real estate agent to use Cal.com for scheduling
RE_CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxx
RE_CAL_EVENT_TYPE_ID=123456

# ── Doctor Agent — Cal.com (Required for doctor agent) ───────────────────────
# Dr. Nehra's Cal.com credentials for appointment booking
DOC_CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxx
DOC_CAL_EVENT_TYPE_ID=123456

# ── Notifications ────────────────────────────────────────────────────────────

# Twilio — for WhatsApp confirmations
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
OWNER_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# Telegram — for admin notifications
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your_chat_id

# ── SIP / Telephony ─────────────────────────────────────────────────────────

# VoBiz SIP trunk configuration
VOBIZ_SIP_DOMAIN=sip.vobiz.in
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# Phone number for call transfers (when agent transfers to human)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Admin Dashboard ──────────────────────────────────────────────────────────

# Login credentials for the frontend dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Webhooks (Optional) ─────────────────────────────────────────────────────

# n8n or custom webhook URL — receives call_completed events
N8N_WEBHOOK_URL=

# ── Monitoring (Optional) ───────────────────────────────────────────────────

# Sentry error tracking DSN
SENTRY_DSN=

# Environment tag for Sentry
ENVIRONMENT=production
